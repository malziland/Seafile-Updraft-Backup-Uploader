<?xml version="1.0"?>
<ruleset name="seafile-updraft-backup-uploader">
    <description>WordPress Coding Standards for seafile-updraft-backup-uploader</description>

    <arg name="extensions" value="php"/>
    <arg name="colors"/>
    <arg value="sp"/>

    <file>.</file>

    <exclude-pattern>vendor/*</exclude-pattern>
    <exclude-pattern>languages/*</exclude-pattern>
    <exclude-pattern>assets/*</exclude-pattern>
    <exclude-pattern>.github/*</exclude-pattern>

    <rule ref="WordPress">
        <exclude name="Generic.Arrays.DisallowShortArraySyntax"/>
        <exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>
        <exclude name="WordPress.Files.FileName.InvalidClassFileName"/>

        <!-- Stilpräferenzen: moderne Lesart statt Yoda, Kurz-Ternary erlaubt,
             keine erzwungenen Docblock-Vollständigkeit. Sicherheitsrelevante
             Sniffs bleiben aktiv. -->
        <exclude name="WordPress.PHP.YodaConditions.NotYoda"/>
        <exclude name="Universal.Operators.DisallowShortTernary"/>
        <exclude name="Squiz.Commenting.InlineComment.InvalidEndChar"/>
        <exclude name="Squiz.Commenting.FunctionComment"/>
        <exclude name="Squiz.Commenting.ClassComment"/>
        <exclude name="Squiz.Commenting.VariableComment"/>
        <exclude name="Squiz.Commenting.FileComment"/>
        <exclude name="Generic.Commenting.DocComment.LongNotCapital"/>
    </rule>

    <config name="minimum_wp_version" value="6.0"/>
    <config name="testVersion" value="8.2-"/>

    <rule ref="PHPCompatibilityWP"/>

    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="seafile-updraft-backup-uploader"/>
            </property>
        </properties>
    </rule>

    <!-- Der NonceVerification-Sniff erkennt nur globale Funktionsaufrufe,
         nicht $this->verify_ajax_request(). Die Unterdrückung erfolgt
         deshalb file-scope in includes/class-sbu-plugin.php mit einem
         prominenten Grund-Block am Dateikopf. -->
</ruleset>
